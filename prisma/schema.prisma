generator client {
  provider = "prisma-client"
  output   = "../app/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id              String           @id
  name            String
  email           String
  emailVerified   Boolean          @default(false)
  image           String?
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  sessions        Session[]
  accounts        Account[]
  role            userrole
  Freelancer      Freelancer?
  userprofiles    Userprofile?
  cancellRequests CancellRequest[]
  activities      Activity[]

  @@unique([email])
  @@map("user")
}

model Session {
  id        String   @id
  expiresAt DateTime
  token     String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  ipAddress String?
  userAgent String?
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([token])
  @@index([userId])
  @@map("session")
}

model Account {
  id                    String    @id
  accountId             String
  providerId            String
  userId                String
  user                  User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  accessToken           String?
  refreshToken          String?
  idToken               String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  password              String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  @@index([userId])
  @@map("account")
}

model Verification {
  id         String   @id
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([identifier])
  @@map("verification")
}

model Payment {
  id                   String                @id @default(cuid())
  total_cost           Int
  paid_amount          Int
  payment_status       Paymentstatus
  due_date             DateTime
  projectId            String?               @unique
  project              Project?              @relation(fields: [projectId], references: [id])
  createdAt            DateTime              @default(now())
  completedAt          DateTime?
  paymentverifications Paymentverification[]

  @@index([projectId])
  @@index([createdAt])
  @@index([payment_status])
}

model Paymentverification {
  id           String             @id @default(cuid())
  txn_number   String             @unique
  paymentid    String
  paid_amount  Int
  status       VerificationStatus @default(PENDING_VERIFICATION)
  imageurl     String?
  freelancerId String
  clientId     String

  createdAt DateTime @default(now())
  updatedAt DateTime @default(now()) @updatedAt

  client     Userprofile @relation(fields: [clientId], references: [id])
  freelancer Freelancer  @relation(fields: [freelancerId], references: [id])
  Payment    Payment     @relation(fields: [paymentid], references: [id])

  @@index([txn_number, freelancerId, clientId])
}

model Freelancer {
  id                String    @id @default(cuid())
  userId            String    @unique
  category          Categorys
  phone             String?
  AccountHolderName String?
  upiId             String?

  user                 User                  @relation(fields: [userId], references: [id], onDelete: Cascade)
  projects             Project[]
  budgetRaiseRequests  BudgetRaiseRequest[]
  paymentverifications Paymentverification[]
  cancellRequests      CancellRequest[]
}

model Userprofile {
  id     String  @id @default(cuid())
  userId String  @unique
  phone  String?

  user                 User                  @relation(fields: [userId], references: [id], onDelete: Cascade)
  projects             Project[]
  paymentverifications Paymentverification[]
  cancellRequests      CancellRequest[]
}

model Milestone {
  id            String          @id @default(cuid())
  title         String
  subtitle      String?
  milestonecost Int
  position      Int
  description   String?
  status        Milestonestatus
  deadline      DateTime
  delay         Boolean?
  delayreason   String? //latest delay only

  project         Project?         @relation(fields: [projectId], references: [id])
  projectId       String?
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  milestonedelays Milestonedelay[]

  @@index([projectId])
  @@index([status])
}

model Milestonedelay {
  id          String   @id @default(cuid())
  milestoneId String
  newDeadline DateTime
  oldDeadline DateTime

  milestone Milestone? @relation(fields: [milestoneId], references: [id])
  createdAt DateTime   @default(now())

  @@index([createdAt, milestoneId])
}

model Project {
  id                   String        @id @default(cuid())
  title                String
  clientId             String?
  clientEmail          String?
  freelancerId         String?
  status               Projectstatus
  agreedCost           Int
  deadline             DateTime
  description          String?
  projectcode          String?       @unique
  hasCancelRequest     Boolean       @default(false)
  archivedByClient     Boolean       @default(false)
  archivedByFreelancer Boolean       @default(false)

  client     Userprofile? @relation(fields: [clientId], references: [id])
  freelancer Freelancer?  @relation(fields: [freelancerId], references: [id])

  milestones Milestone[]
  payments   Payment[]

  createdAt           DateTime             @default(now())
  updatedAt           DateTime             @updatedAt
  stoppedAt           DateTime?
  budgetRaiseRequests BudgetRaiseRequest[]
  cancellRequests     CancellRequest[]
  activities          Activity[]

  @@index([freelancerId])
  @@index([clientId])
  @@index([createdAt])
}

model Activity {
  id                String       @id @default(cuid())
  type              ActivityType
  dateTimeofMessage DateTime
  message           String
  highlightmessage  String
  projectId         String
  userId            String
  user              User         @relation(fields: [userId], references: [id])
  project           Project      @relation(fields: [projectId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@index([userId, createdAt, projectId, type])
}

model BudgetRaiseRequest {
  id String @id @default(cuid())

  projectId String
  project   Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  requestedById   String // freelancerId
  requestedby     Freelancer @relation(fields: [requestedById], references: [id])
  currentBudget   Int
  requestedBudget Int
  reason          String?

  status BudgetRequestStatus @default(PENDING)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  reviewedAt DateTime?

  @@index([status, createdAt, reviewedAt, requestedById])
}

model CancellRequest {
  id                 String      @id @default(cuid())
  freelancerApproved Boolean     @default(false)
  clientApproved     Boolean     @default(false)
  clientId           String
  client             Userprofile @relation(fields: [clientId], references: [id])
  freelancerId       String
  freelancer         Freelancer  @relation(fields: [freelancerId], references: [id])
  raiesdByuserId     String
  raisedBy           User        @relation(fields: [raiesdByuserId], references: [id])
  acceptedById       String?
  rejectedById       String?
  createdAt          DateTime    @default(now())
  approvedAt         DateTime?
  isRejected         Boolean     @default(false)

  projectId String  @unique
  project   Project @relation(fields: [projectId], references: [id])

  @@index([freelancerId, freelancerApproved, clientId, clientApproved])
}

enum Categorys {
  WEB_DEV
  VIDEO_EDITOR
  GRAPHIC_DESIGNER
  WEB_DESIGNER
  SEO
}

enum Milestonestatus {
  COMPLETED
  NOT_STARTED
  IN_PROGRESS
  STOPPED
}

enum Paymentstatus {
  DUE
  PAID
}

enum userrole {
  FREELANCER
  CLIENT
}

enum Projectstatus {
  COMPLETED
  ACTIVE
  PENDING
  STOPPED
  CANCELLED
}

enum BudgetRequestStatus {
  PENDING
  APPROVED
  REJECTED
}

enum VerificationStatus {
  VERIFIED
  PENDING_VERIFICATION
  REJECTED
}

enum ActivityType {
  DELAY
  PAYMENT
  MILESTONEDONE
  REMINDER
}
